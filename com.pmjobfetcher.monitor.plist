        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/jeyvenkat/Library/Mobile Documents/com~apple~CloudDocs/Downloads/LandPM BootCamp/Job Fetcher/output/monitor.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/jeyvenkat/Library/Mobile Documents/com~apple~CloudDocs/Downloads/LandPM BootCamp/Job Fetcher/output/monitor_error.log</string>
</dict>
</plist>
